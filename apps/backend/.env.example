# Heydo backend — example env. Copy to .env (never commit .env).
NODE_ENV=development
PORT=3000
API_PUBLIC_URL=
CORS_ORIGINS=

# Persistence
PERSISTENCE=memory          # memory | postgres
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_CA_FILE=

# Auth
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# PII vault (dev). In prod this comes from AWS KMS / Secrets Manager — NOT here.
PII_ENCRYPTION_KEY=dev-only-32-byte-key-change-me!!

# Vendor selection (local dev uses 'mock'; Didit is the first live VKYC vendor)
VKYC_PROVIDER=mock          # mock | didit
OTP_SENDER=mock             # mock | msg91 | sns

# Didit VKYC (backend-only; never expose in Flutter/admin/browser bundles)
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
# Optional but recommended before real marketplace posting: separate Didit
# workflow for gig givers/posters. Falls back to DIDIT_WORKFLOW_ID if blank.
DIDIT_GIVER_WORKFLOW_ID=
DIDIT_BASE_URL=https://verification.didit.me/v3
DIDIT_CALLBACK_URL=
DIDIT_WEBHOOK_SECRET=
# Didit docs do not publicly list Malayalam ('ml') yet. Keep Heydo's UX
# Malayalam-first, then fall back inside Didit's hosted flow until supported.
DIDIT_LANGUAGE_FALLBACK=en
