# Heydo backend — example env. Copy to .env (never commit .env).
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# PII vault (dev). In prod this comes from AWS KMS / Secrets Manager — NOT here.
PII_ENCRYPTION_KEY=dev-only-32-byte-key-change-me!!

# Vendor selection (Phase 1 uses 'mock' until real contracts are signed)
VKYC_PROVIDER=mock          # mock | signzy | hyperverge | idfy
OTP_SENDER=mock             # mock | msg91 | sns
