{
  "name": "heydo",
  "version": "0.1.0",
  "private": true,
  "description": "Heydo — trust-first gig marketplace for Kerala. Monorepo: Flutter app + NestJS backend + Next.js admin.",
  "workspaces": [
    "apps/backend"
  ],
  "scripts": {
    "test": "npm run test --workspace apps/backend",
    "build": "npm run build --workspace apps/backend",
    "db:schema:apply": "npm run db:schema:apply --workspace apps/backend",
    "deploy:readiness": "npm run deploy:readiness --workspace apps/backend",
    "mobile:qa": "node apps/mobile/scripts/check-flutter-qa.mjs",
    "vkyc:readiness": "npm run vkyc:readiness --workspace apps/backend",
    "start:backend": "npm run start --workspace apps/backend"
  },
  "engines": {
    "node": ">=20"
  }
}
